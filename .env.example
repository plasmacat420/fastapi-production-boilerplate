APP_NAME=FastAPI Boilerplate
APP_VERSION=0.1.0
DEBUG=false

# Database — update with your actual credentials
DATABASE_URL=postgresql+asyncpg://boilerplate:boilerplate@localhost/boilerplate
TEST_DATABASE_URL=sqlite+aiosqlite:///./test.db

# JWT — CHANGE THIS before deploying
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-256-bit-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis
REDIS_URL=redis://localhost:6379/0

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
